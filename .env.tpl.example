# Example template file for sm (commit this to git as reference)
# Copy this file to .env.tpl for local development: cp .env.tpl.example .env.tpl

# 1. Convention-based secret lookup
# Looks up candidate secret names in GCP Secret Manager automatically based on environment:
# e.g., dev-database-url, database-url-dev, database-url, etc.
DATABASE_URL=sm://

# 2. Explicit secret name lookup (in the active GCP project)
STRIPE_SECRET_KEY=sm://production-stripe-key

# 3. Fully qualified Secret Manager resource path
CLOUD_SQL_PASSWORD=sm://projects/my-production-project/secrets/sql-password/versions/1

# 4. Secret File Injection (writes secret to disk with 0600 permissions, deletes it securely on exit)
# SSL_CERT_PATH will be populated with the absolute path to './test_cert.pem'
SSL_CERT_PATH=sm://db-ssl-cert?destination=./test_cert.pem

# 5. Standard non-secret environment variables (passed through as-is)
DEBUG=true
PORT=8080
LOG_LEVEL=info
