# Local overrides example for sm (gitignored)
# Copy this file to .env.local for local offline development: cp .env.local.example .env.local
# Values specified here override .env.tpl and Secret Manager lookups.

# Override DATABASE_URL secret locally without making GCP API calls
DATABASE_URL="postgres://postgres:postgres@localhost:5432/my_local_db"

# Override other secrets as needed
STRIPE_SECRET_KEY="sk_test_mock_stripe_key"
